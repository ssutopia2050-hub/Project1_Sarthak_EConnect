<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Set New Password</title>
    <link rel="stylesheet" href="/set_new_password.css">
    <link rel="icon" type="image/x-icon" href="/icons8-study-arcade-96.png">
</head>
<body>

<div class="card">
    <div class="logo">
        <img src="/Logo.png" alt="Logo">
    </div>
    <h1 style="color:rgba(0, 255, 200, 0.51)">Set New Password</h1>

    <% if (error) { %>
    <p style="color:red;"><%= error %></p>
    <% } %>
<div class="form-container">
    <form method="POST" action="/set_new_password">

        <input
                type="password"
                name="password"
                placeholder="Enter new password"
                required
        >

        <input
                type="password"
                name="confirmPassword"
                placeholder="Confirm new password"
                required
        >

        <button type="submit">Update Password</button>
    </form>
</div>

</div>

</body>
</html>